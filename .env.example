APP_NAME=Deepfake Detection API
APP_VERSION=21.0.0
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:8080

CONFIG_PATH=models/config.json
MODEL_PATH=models/best_v21_manual_audit_local_similarity.pkl
SCALER_PATH=models/feature_scaler.pkl
YOLO_PATH=models/face_yolov8n.pt
XCEPTION_ENCODER_PATH=models/xception_frame_encoder_safe.keras
MODEL_METADATA_PATH=models/model_metadata.json

TEMP_FOLDER=temp
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=300
UPLOAD_CHUNK_BYTES=1048576
PRESERVE_UPLOADS=false
INFERENCE_CONCURRENCY=1
INFERENCE_QUEUE_TIMEOUT=900
MAX_UPLOAD_QUEUE=5
TENSORFLOW_THREADS=1
TORCH_THREADS=1
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
OPENBLAS_NUM_THREADS=2
NUMEXPR_NUM_THREADS=2
TF_NUM_INTRAOP_THREADS=2
TF_NUM_INTEROP_THREADS=1
YOLO_BATCH_SIZE=4
YOLO_DEVICE=cpu
YOLO_VERBOSE=false
XCEPTION_BATCH_SIZE=8
MODEL_WARMUP=false
DEEPFAKE_DEBUG_PIPELINE=false
SAVE_DEBUG_FRAMES=false
